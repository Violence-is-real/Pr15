<UserControl x:Class="Pr15.AssembliesUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Pr15"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Сохранённые сборки" 
               FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
        <!--Список сборок-->
        <ListView x:Name="lvAssemblies" Grid.Row="1" 
           SelectionChanged="lvAssemblies_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название сборки" Width="380" 
                             DisplayMemberBinding="{Binding name}"/>
                    <GridViewColumn Header="Автор" Width="200" 
                             DisplayMemberBinding="{Binding author}"/>
                    <GridViewColumn Header="Цена" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=id}" 
                                    FontWeight="SemiBold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        <!--Список комплектующих сборки-->
        <GroupBox Header="Состав сборки" Grid.Row="2" Margin="0,15,0,0" Padding="10">
            <ListView x:Name="lvAssemblyParts" Height="280">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Комплектующее" Width="420" 
                                DisplayMemberBinding="{Binding name}"/>
                        <GridViewColumn Header="Производитель" Width="220" 
                                DisplayMemberBinding="{Binding manufacturer}"/>
                        <GridViewColumn Header="Цена" Width="140" 
                                DisplayMemberBinding="{Binding price, StringFormat={}{0:N0} ₽}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
    </Grid>
</UserControl>
