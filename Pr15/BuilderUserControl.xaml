<UserControl x:Class="Pr15.BuilderUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Pr15"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <!--Категории-->
            <ColumnDefinition Width="2*"/>
            <!--Список комплектующих-->
            <ColumnDefinition Width="300"/>
            <!--Выбранные комплектующие-->
            <ColumnDefinition Width="280"/>
            <!--цена + сохранение-->
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="10,10,10,5">
            <TextBlock Text="Поиск:" Margin="0,5,5,0" FontSize="14" VerticalAlignment="Center"/>
            <TextBox x:Name="txtSearch" Width="280" Height="32" TextChanged="txtSearch_TextChanged" 
             FontSize="14" Padding="5"/>

            <TextBlock Text="Производитель:" Margin="20,5,5,0" FontSize="14" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbManufacturer" Width="200" Height="32" DisplayMemberPath="name"
              SelectionChanged="cmbManufacturer_SelectionChanged" FontSize="14"/>
        </StackPanel>
        <!--Категории комплект.-->
        <ListBox x:Name="lstCategories" Grid.Row="1" Grid.Column="0" Margin="10" 
          SelectionChanged="lstCategories_SelectionChanged"
          FontSize="14" BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Padding="5" FontSize="15"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <!--Список комплектующих-->
        <ListView x:Name="lvParts" Grid.Row="1" Grid.Column="1" Margin="10" 
          SelectionMode="Single" MouseDoubleClick="lvParts_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Изображение" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding image}" Width="70" Height="70" Stretch="Uniform"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Название" Width="280" DisplayMemberBinding="{Binding name}"/>
                    <GridViewColumn Header="Производитель" Width="140" DisplayMemberBinding="{Binding manufacturer_.name}"/>
                    <GridViewColumn Header="Цена" Width="100" DisplayMemberBinding="{Binding price, StringFormat={}{0:C}}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
